defaults
auth           on
tls            on
logfile        ~/.local/share/msmtp/msmtp.log

account        proton
host           127.0.0.1
port           1025
from           j@ckruder.xyz
user           j@ckruder.xyz
passwordeval   "pass show email/proton-bridge"
tls_starttls   on
tls_trust_file ~/.config/protonmail/bridge-v3/cert.pem

account default : proton

